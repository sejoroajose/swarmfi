# AXL
RESEARCHER_API=http://127.0.0.1:9002
RISK_API=http://127.0.0.1:9012
EXECUTOR_API=http://127.0.0.1:9022

ZG_RPC_URL=
ZG_PRIVATE_KEY=
ZG_COMPUTE_API_KEY=
ZG_COMPUTE_BASE_URL=https://router-api-testnet.integratenetwork.work/v1
ZG_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct

UNISWAP_API_KEY=

KEEPERHUB_API_KEY=
# The KeeperHub-managed wallet that will sign and broadcast every swap.
# Find this in your KeeperHub dashboard (Wallet Management) or in the
# `from` field of any failed contract-call on basescan. Set this to the
# same value when funding the wallet — it must hold ETH on Base.
KH_KEEPER_ADDRESS=
# Receiving wallet (only used as fallback if KH_KEEPER_ADDRESS unset).
WALLET_ADDRESS=
WALLET_PRIVATE_KEY=

# Treasury commitment: every approved trade decision is recorded on-chain
# by a small ETH transfer from the keeper. The transfer runs on a network
# the KeeperHub-managed Turnkey wallet officially supports — Sepolia by
# default (free testnet ETH from any faucet) or "ethereum" for mainnet.
# The Uniswap *quote* still uses Base mainnet — only the commitment
# settles on the commitment network.
SWARMFI_COMMITMENT_NETWORK=sepolia
SWARMFI_COMMITMENT_ETH=0.0001
SWARMFI_COMMITMENT_RECIPIENT=

# Dashboard port (default 8080)
DASHBOARD_PORT=8080

# Risk settings
RISK_THRESHOLD=7.0
SCAN_INTERVAL=60